---
interface Props {
	phoneNumber: string;
	message?: string;
	label?: string;
}

const {
	phoneNumber,
	message = "Hola, quiero más información sobre StashIMS.",
	label = "Escribir por WhatsApp",
} = Astro.props as Props;

const digitsOnlyPhone = phoneNumber.replace(/\D/g, "");
const whatsappUrl = `https://wa.me/${digitsOnlyPhone}${message ? `?text=${encodeURIComponent(message)}` : ""}`;
---

<a
	aria-label={label}
	class="fixed bottom-5 right-5 z-50 flex items-center gap-3 rounded-full bg-[#25D366] px-4 py-3 text-white shadow-2xl shadow-emerald-500/30 transition-transform hover:-translate-y-1 active:scale-95 sm:bottom-6 sm:right-6"
	href={whatsappUrl}
	target="_blank"
	rel="noopener noreferrer"
>
	<span class="flex h-11 w-11 items-center justify-center rounded-full bg-white/15">
		<svg aria-hidden="true" class="h-6 w-6 fill-current" viewBox="0 0 32 32">
			<path d="M19.11 17.45c-.27-.14-1.58-.78-1.82-.87-.24-.09-.42-.14-.6.14-.18.27-.69.87-.85 1.05-.16.18-.31.2-.58.07-.27-.14-1.12-.41-2.13-1.31-.79-.7-1.32-1.56-1.47-1.83-.16-.27-.02-.42.12-.56.12-.12.27-.31.4-.46.14-.16.18-.27.27-.45.09-.18.05-.33-.02-.46-.07-.14-.6-1.45-.82-1.98-.21-.51-.43-.44-.6-.45h-.51c-.18 0-.46.07-.7.33-.24.27-.92.9-.92 2.2 0 1.3.94 2.55 1.07 2.73.14.18 1.86 2.84 4.51 3.98.63.27 1.12.43 1.5.55.63.2 1.2.17 1.65.1.5-.08 1.58-.65 1.8-1.28.22-.63.22-1.17.15-1.28-.07-.11-.24-.18-.51-.32Z" />
			<path d="M16.02 2C8.83 2 3 7.73 3 14.79c0 2.55.78 4.95 2.12 6.94L3.45 29l7.52-1.58a13.43 13.43 0 0 0 5.05 1c7.19 0 13.02-5.73 13.02-12.79S23.21 2 16.02 2Zm0 23.28c-1.67 0-3.24-.44-4.61-1.19l-.33-.19-4.46.94.95-4.25-.21-.36a10.98 10.98 0 0 1-1.67-5.84c0-6.02 4.99-10.91 11.13-10.91s11.13 4.89 11.13 10.91-4.99 10.89-11.13 10.89Z" />
		</svg>
	</span>
	<span class="hidden pr-1 text-sm font-bold sm:inline">WhatsApp</span>
</a>
