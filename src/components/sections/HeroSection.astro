---
const phoneNumber = "50768382443";
const message = "Hola, quiero más información sobre StashIMS.";
const whatsappUrl = `https://wa.me/${phoneNumber}?text=${encodeURIComponent(message)}`;
---
<section class="relative min-h-[795px] pt-20 lg:pt-0 flex items-center overflow-hidden bg-surface-bright">
	<div class="max-w-7xl mx-auto px-8 grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
		<div class="z-15">
			<span class="inline-block px-4 py-1.5 bg-primary-container/10 text-primary font-bold text-xs uppercase tracking-widest rounded-full mb-6">
				Inventario inteligente para PyMEs en Latinoamérica
			</span>
			<h1 class="font-headline text-5xl md:text-7xl font-extrabold text-on-surface leading-[1.1] tracking-tighter mb-6">
				Controla tu inventario en <span class="text-gradient">tiempo real con StashIMS</span>
			</h1>
			<p class="text-on-surface-variant text-xl leading-relaxed mb-10 max-w-xl">
				Gestiona entradas, salidas, stock por ubicación y reportes de valorización. Todo desde un solo panel diseñado para PyMEs que quieren crecer sin desorden.
			</p>
			<div class="flex flex-wrap gap-4">
				<a class="primary-gradient-btn text-on-primary px-8 py-4 rounded-xl font-bold text-lg active:scale-95 transition-transform shadow-lg shadow-primary/20" href="#formulario">
					Solicitar demo
				</a>
				<a class="bg-surface-container-highest text-on-surface px-8 py-4 rounded-xl font-bold text-lg active:scale-95 transition-transform hover:bg-surface-dim transition-colors" href="#formulario">
					Prueba gratis
				</a>
				<a class="flex items-center gap-2 text-primary font-bold px-4 py-4 hover:underline underline-offset-4" href={whatsappUrl} target="_blank" rel="noopener noreferrer">
					<span class="material-symbols-outlined">chat</span>
					Contáctanos por WhatsApp
				</a>
			</div>
		</div>
		<div class="relative">
			<div class="absolute -top-20 -right-20 w-96 h-96 bg-secondary-container/20 blur-[100px] rounded-full"></div>
			<div class="relative rounded-[2.5rem] overflow-hidden shadow-2xl">
				<img alt="Panel de control de StashIMS con gestión de inventario en tiempo real para PyMEs en Latinoamérica" class="w-full aspect-[4/3] object-cover" src="hero.png"/>
				<div class="absolute bottom-8 left-8 right-8 glass-panel p-6 rounded-2xl shadow-xl">
					<div class="flex justify-between items-end">
						<div>
							<p class="text-label-sm uppercase font-bold text-primary tracking-widest mb-1">Control Total</p>
							<p class="text-2xl font-black font-headline text-on-surface">En tiempo real</p>
						</div>
						<div class="bg-primary-container text-white p-2 rounded-lg">
							<span class="material-symbols-outlined">trending_up</span>
						</div>
					</div>
				</div>
			</div>
		</div>
	</div>
</section>
